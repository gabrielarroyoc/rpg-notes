# =====================================================
#  RPG Notes — variáveis de ambiente
# =====================================================
# Copie este arquivo para `.env` (já está no .gitignore)
# e preencha os valores. Reinicie o dev server depois.
#
# Todas as variáveis usadas no front DEVEM começar com VITE_
# para o Vite expô-las (import.meta.env.VITE_*).

# -----------------------------------------------------
# Supabase (opcional por enquanto — modo offline funciona sem)
# -----------------------------------------------------
# Pegue em: https://supabase.com/dashboard → seu projeto → Settings → API
# - VITE_SUPABASE_URL: campo "Project URL"
# - VITE_SUPABASE_ANON_KEY: campo "Project API keys → anon / public"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------
# Cloudflare R2 (futuro — quando trocar o image-storage)
# -----------------------------------------------------
# VITE_R2_PUBLIC_URL=
# VITE_R2_BUCKET=
